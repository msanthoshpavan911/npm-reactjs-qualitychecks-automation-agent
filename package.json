{
  "name": "reactjsquality-check911",
  "version": "1.1.5",
  "description": "GitHub Copilot agent for React/TypeScript projects — enforces ESLint, Jest + React Testing Library coverage, Playwright, and npm audit on every commit",
  "bin": {
    "reactjsquality-check911": "./bin/reactjsquality-check911.js"
  },
  "scripts": {
    "test": "echo \"No tests\" && exit 0",
    "postinstall": "node scripts/setup-mcp.js"
  },
  "keywords": [
    "react",
    "nextjs",
    "typescript",
    "eslint",
    "jest",
    "react-testing-library",
    "playwright",
    "copilot",
    "mcp",
    "quality",
    "git-hooks"
  ],
  "author": "mamidi-santhosh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "commands/",
    "scripts/",
    "config/",
    "mcp-server/server.py",
    "mcp-server/tools/*.py",
    "mcp-server/requirements.txt"
  ],
  "type": "commonjs",
  "dependencies": {
    "@typescript-eslint/parser": "^7.0.0",
    "commander": "^15.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-sonarjs": "^0.25.0",
    "eslint-plugin-security": "^3.0.0"
  }
}
